package project;

import javax.swing.*;
import java.awt.*;
import java.awt.event.*;

public class KBCAdvanced extends JFrame implements ActionListener {

    JLabel questionLabel, moneyLabel, timerLabel;
    JButton A, B, C, D, lifeline, quit;

    int qIndex = 0, total = 0, safeAmount = 0;
    int timeLeft = 40;   // ✅ Timer set to 40 seconds

    Timer timer;

    boolean used5050 = false, usedAudience = false, usedSkip = false;

    String questions[] = {
            "Capital of India?",
            "2 + 2 = ?",
            "Largest planet?",
            "Java is a?",
            "National animal?",
            "10 * 5 = ?",
            "Not a language?",
            "Sun is a?",
            "Fastest animal?",
            "Founder of Microsoft?"
    };

    String options[][] = {
            {"Delhi","Mumbai","Kolkata","Chennai"},
            {"3","4","5","6"},
            {"Earth","Mars","Jupiter","Venus"},
            {"Language","OS","Browser","Hardware"},
            {"Tiger","Lion","Elephant","Dog"},
            {"40","50","60","30"},
            {"Java","Python","HTML","C++"},
            {"Planet","Star","Galaxy","Moon"},
            {"Tiger","Lion","Cheetah","Dog"},
            {"Steve Jobs","Bill Gates","Elon Musk","Mark"}
    };

    char answers[] = {'A','B','C','A','A','B','C','B','C','B'};
    int rewards[] = {1000,2000,3000,5000,10000,20000,40000,80000,160000,320000};

    public KBCAdvanced() {

        setTitle("KBC Game");
        setSize(600,450);
        setLayout(new GridLayout(9,1));
        getContentPane().setBackground(Color.BLACK);

        questionLabel = new JLabel("", JLabel.CENTER);
        questionLabel.setForeground(Color.WHITE);
        questionLabel.setFont(new Font("Arial", Font.BOLD, 18));

        timerLabel = new JLabel("Time: 40", JLabel.CENTER);
        timerLabel.setForeground(Color.YELLOW);

        moneyLabel = new JLabel("Money: 0", JLabel.CENTER);
        moneyLabel.setForeground(Color.GREEN);

        A = createButton();
        B = createButton();
        C = createButton();
        D = createButton();

        lifeline = createButton("Lifeline");
        quit = createButton("Quit");

        add(questionLabel);
        add(timerLabel);
        add(A); add(B); add(C); add(D);
        add(lifeline); add(quit);
        add(moneyLabel);

        loadQuestion();
        startTimer();

        setVisible(true);
        setDefaultCloseOperation(EXIT_ON_CLOSE);
    }

    JButton createButton() {
        JButton btn = new JButton();
        btn.setBackground(Color.DARK_GRAY);
        btn.setForeground(Color.WHITE);
        btn.addActionListener(this);
        return btn;
    }

    JButton createButton(String text) {
        JButton btn = createButton();
        btn.setText(text);
        return btn;
    }

    void startTimer() {
        timer = new Timer(1000, e -> {
            timeLeft--;
            timerLabel.setText("Time: " + timeLeft);

            if (timeLeft == 0) {
                timer.stop();
                JOptionPane.showMessageDialog(this, "Time Up!");
                total = safeAmount; // go to safe amount
                gameOver();
            }
        });
        timer.start();
    }

    void resetTimer() {
        timeLeft = 40;
        timerLabel.setText("Time: 40");
    }

    void loadQuestion() {

        if (qIndex >= 10) {
            gameOver();
            return;
        }

        questionLabel.setText("Q" + (qIndex+1) + ": " + questions[qIndex]);

        A.setText("A. " + options[qIndex][0]);
        B.setText("B. " + options[qIndex][1]);
        C.setText("C. " + options[qIndex][2]);
        D.setText("D. " + options[qIndex][3]);

        lifeline.setEnabled(qIndex < 8);

        // Enable all options again (important after 50-50)
        A.setEnabled(true);
        B.setEnabled(true);
        C.setEnabled(true);
        D.setEnabled(true);

        resetTimer();
    }

    public void actionPerformed(ActionEvent e) {

        if (e.getSource() == quit) {
            total = safeAmount;
            gameOver();
        }

        if (e.getSource() == lifeline && qIndex < 8) {
            showLifeline();
            return;
        }

        char selected = ' ';

        if (e.getSource() == A) selected = 'A';
        if (e.getSource() == B) selected = 'B';
        if (e.getSource() == C) selected = 'C';
        if (e.getSource() == D) selected = 'D';

        checkAnswer(selected);
    }

    void checkAnswer(char selected) {

        if (selected == answers[qIndex]) {

            // ✅ Only add money at Q5 and Q7
            if (qIndex == 4 || qIndex == 6) {
                total = rewards[qIndex];
                safeAmount = total; // safe point
                moneyLabel.setText("Money: " + total);
            }

            qIndex++;
            loadQuestion();

        } else {
            JOptionPane.showMessageDialog(this, "Wrong Answer!");
            total = safeAmount;
            gameOver();
        }
    }

    void showLifeline() {

        String input = JOptionPane.showInputDialog(
                "1. 50-50\n2. Audience\n3. Skip");

        int ch = Integer.parseInt(input);

        if (ch == 1 && !used5050) {
            used5050 = true;
            B.setEnabled(false);
            D.setEnabled(false);

        } else if (ch == 2 && !usedAudience) {
            usedAudience = true;
            JOptionPane.showMessageDialog(this,
                    "Audience says: " + answers[qIndex]);

        } else if (ch == 3 && !usedSkip) {
            usedSkip = true;
            qIndex++;
            loadQuestion();

        } else {
            JOptionPane.showMessageDialog(this, "Already Used!");
        }
    }

    void gameOver() {
        timer.stop();
        JOptionPane.showMessageDialog(this,
                "Game Over!\nWinning Amount: " + total);
        System.exit(0);
    }

    public static void main(String[] args) {
        new KBCAdvanced();
    }
}
