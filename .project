package project;
import java.util.Scanner;
public class colorquiz {
	    static Scanner sc = new Scanner(System.in);

	    // 🎨 Colors
	    static final String RESET = "\u001B[0m";
	    static final String RED = "\u001B[31m";
	    static final String GREEN = "\u001B[32m";
	    static final String YELLOW = "\u001B[33m";
	    static final String BLUE = "\u001B[34m";
	    static final String CYAN = "\u001B[36m";

	    public static void main(String[] args) {

	        String questions[] = {
	                "Capital of India?",
	                "2 + 2 = ?",
	                "Largest planet?",
	                "Java is a?",
	                "National animal of India?",
	                "10 * 5 = ?",
	                "Which is not a programming language?",
	                "Sun is a?",
	                "Fastest animal?",
	                "Founder of Microsoft?"
	        };

	        String options[][] = {
	                {"A. Delhi", "B. Mumbai", "C. Kolkata", "D. Chennai"},
	                {"A. 3", "B. 4", "C. 5", "D. 6"},
	                {"A. Earth", "B. Mars", "C. Jupiter", "D. Venus"},
	                {"A. Language", "B. OS", "C. Browser", "D. Hardware"},
	                {"A. Tiger", "B. Lion", "C. Elephant", "D. Dog"},
	                {"A. 40", "B. 50", "C. 60", "D. 30"},
	                {"A. Java", "B. Python", "C. HTML", "D. C++"},
	                {"A. Planet", "B. Star", "C. Galaxy", "D. Moon"},
	                {"A. Tiger", "B. Lion", "C. Cheetah", "D. Dog"},
	                {"A. Steve Jobs", "B. Bill Gates", "C. Elon Musk", "D. Mark"}
	        };

	        char answers[] = {'A','B','C','A','A','B','C','C','C','B'};

	        int rewards[] = {1000,2000,3000,5000,10000,20000,40000,80000,160000,320000};

	        boolean lifeline5050 = true;
	        boolean audience = true;
	        boolean skip = true;

	        int total = 0;
	        int safeAmount = 0;

	        System.out.println(CYAN + " Welcome to KBC Game " + RESET);

	        for (int i = 0; i < 10; i++) {

	            System.out.println("\n" + BLUE + "Q" + (i+1) + ": " + questions[i] + RESET);

	            for (int j = 0; j < 4; j++) {
	                System.out.println(options[i][j]);
	            }

	            if (i < 8) {
	                System.out.println(YELLOW + "L. Lifeline" + RESET);
	            }
	            System.out.println(RED + "Q. Quit" + RESET);

	            System.out.print(GREEN + "Enter your answer: " + RESET);
	            char choice = sc.next().toUpperCase().charAt(0);

	            // Quit
	            if (choice == 'Q') {
	                System.out.println(YELLOW + "You quit the game!" + RESET);
	                break;
	            }

	            // Lifeline
	            if (choice == 'L' && i < 8) {

	                System.out.println(CYAN + "Choose Lifeline:" + RESET);
	                System.out.println("1. 50-50");
	                System.out.println("2. Audience Poll");
	                System.out.println("3. Skip Question");

	                int life = sc.nextInt();

	                if (life == 1 && lifeline5050) {
	                    lifeline5050 = false;
	                    System.out.println(YELLOW + "50-50 Lifeline Used!" + RESET);
	                    System.out.println(options[i][0]);
	                    System.out.println(options[i][2]);
	                    i--; continue;

	                } else if (life == 2 && audience) {
	                    audience = false;
	                    System.out.println(YELLOW + "Audience says: " + answers[i] + RESET);
	                    i--; continue;

	                } else if (life == 3 && skip) {
	                    skip = false;
	                    System.out.println(YELLOW + "Question Skipped!" + RESET);
	                    continue;

	                } else {
	                    System.out.println(RED + "Lifeline already used!" + RESET);
	                    i--; continue;
	                }
	            }

	            // Check answer
	            if (choice == answers[i]) {
	                System.out.println(GREEN + " Correct Answer!" + RESET);
	                total = rewards[i];

	                if (i == 4) safeAmount = rewards[4]; // Q5 safe
	                if (i == 6) safeAmount = rewards[6]; // Q7 safe

	                System.out.println(CYAN + "You won: " + total + RESET);

	            } else {
	                System.out.println(RED + " Wrong Answer!" + RESET);
	                total = safeAmount;
	                break;
	            }
	        }

	        System.out.println("\n" + BLUE + " Game Over!" + RESET);
	        System.out.println(GREEN + "Total Winning Amount: " + total + RESET);
	    }
	}
